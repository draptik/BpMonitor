{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-workflow-reminder.sh\"",
            "statusMessage": "Checking git-workflow rules..."
          },
          {
            "type": "command",
            "if": "Bash(gh *)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-workflow-reminder.sh\"",
            "statusMessage": "Checking git-workflow rules..."
          }
        ]
      }
    ]
  }
}