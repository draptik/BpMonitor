{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "shellcheck",
         "group": "pre-commit",
         "command": "mise",
         "args": ["exec", "--", "shellcheck", "${staged}"],
         "include": ["**/*.sh"],
         "exclude": [".husky/_/*.sh"],
         "staged": true
      },
      {
         "name": "markdownlint",
         "group": "pre-commit",
         "command": "mise",
         "args": ["exec", "--", "markdownlint-cli2", "${staged}"],
         "include": ["**/*.md"],
         "staged": true
      },
      {
         "name": "fantomas-check",
         "group": "pre-commit",
         "command": "dotnet",
         "args": ["fantomas", "${staged}"],
         "include": ["code/**/*.fs"],
         "pathMode": "absolute",
         "cwd": "code",
         "staged": true
      },
      {
         "name": "biome",
         "group": "pre-commit",
         "command": "mise",
         "args": ["exec", "--", "biome", "lint", "${staged}"],
         "include": ["code/BpMonitor.Web/wwwroot/*.js"],
         "exclude": ["**/*.min.js"],
         "staged": true
      }
   ]
}
