{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "shellcheck",
         "group": "pre-commit",
         "command": "shellcheck",
         "args": ["${staged}"],
         "include": ["**/*.sh"],
         "exclude": [".husky/_/*.sh"],
         "staged": true
      },
      {
         "name": "markdownlint",
         "group": "pre-commit",
         "command": "markdownlint-cli2",
         "args": ["${staged}"],
         "include": ["**/*.md"],
         "staged": true
      },
      {
         "name": "fantomas-check",
         "group": "pre-commit",
         "command": "dotnet",
         "args": ["fantomas", "${staged}"],
         "include": ["code/**/*.fs"],
         "pathMode": "absolute",
         "cwd": "code",
         "staged": true
      }
   ]
}
