root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{fs,fsx,fsi}]
indent_style = space
indent_size = 2

[*.{cs,csx}]
indent_style = space
indent_size = 4

[*.{fsproj,csproj,props,targets,slnx,config,xml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
